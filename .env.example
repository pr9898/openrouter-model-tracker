# OpenRouter 模型检测 — 环境变量模板
# 复制为 .env 后填写,或直接用 GitHub Actions Secrets / 系统环境变量

# OpenRouter API Key(公开 API 无需设置,留空即可)
OPENROUTER_API_KEY=

# OpenRouter API 地址(默认即可)
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# 企业微信群机器人 Webhook Key(不设置则跳过通知)
# 在企业微信群 → 添加群机器人 → 复制 Webhook 地址末尾的 key
WECHAT_WEBHOOK_KEY=

# HuggingFace Token(强烈建议,将速率限制从 500/5min 提升到 1000/5min)
# 免费注册后在 https://huggingface.co/settings/tokens 生成
HF_TOKEN=
