<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openrouter.model-checker</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/bin/openrouter-model-check.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>6</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/com.openrouter.model-checker.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/com.openrouter.model-checker.err.log</string>
</dict>
</plist>
